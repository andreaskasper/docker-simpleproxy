# ============================================
# SimpleProxy Configuration
# ============================================
# Complete documentation: https://github.com/andreaskasper/docker-simpleproxy

# ============================================
# 🎯 CORE SETTINGS (Required)
# ============================================

# Your backend server (origin) - the site you want to cache
# Example: cms.internal.company.com, backend.mysite.local, wp.staging.example.com
# NOTE: Do NOT include https:// or http:// prefix
TARGET_HOST=ptr.example.com

# What domain visitors see in their browser
# Leave empty for auto-detection from HTTP_HOST header
# Example: example.com, mysite.com, shop.example.org
PUBLIC_HOST=example.com

# Backend protocol: https or http
# Use 'http' for local development, 'https' for production
PROXY_SCHEME=https

# ============================================
# ⏱️ CACHING SETTINGS
# ============================================

# How long browsers should cache content (seconds)
# Examples:
#   3600 = 1 hour (default, good for frequently updated sites)
#   86400 = 24 hours (good for daily updates)
#   604800 = 1 week (good for event sites, portfolios)
#   2592000 = 30 days (good for very static sites)
CACHE_MAX_AGE=3600

# Stale-while-revalidate: Serve stale content while fetching fresh (seconds)
# Improves performance by serving cached content immediately while updating in background
# Examples:
#   86400 = 24 hours (default)
#   604800 = 1 week (aggressive caching)
CACHE_STALE_REVALIDATE=86400

# Stale-if-error: Serve stale content if backend is down (seconds)
# Keeps site online even when backend fails
CACHE_STALE_ERROR=86400

# Enable ETag headers for efficient 304 Not Modified responses
# true = Generate ETags (recommended)
# false = Disable ETags (not recommended)
ENABLE_ETAG=true

# ============================================
# 🎯 PATH CONTROL
# ============================================

# Paths to NEVER cache (comma-separated, regex supported)
# These paths will always be fetched fresh from backend
# 
# Common WordPress exclusions:
# EXCLUDED_PATHS=/wp-admin,/wp-login.php,/wp-json,/xmlrpc.php,/wp-cron.php
#
# E-commerce exclusions:
# EXCLUDED_PATHS=/cart,/checkout,/my-account,/payment
#
# Generic exclusions:
# EXCLUDED_PATHS=/admin,/login,/api,/auth,/webhook
#
# Regex patterns (advanced):
# EXCLUDED_PATHS=/api/.*,/admin.*,.*submit.*
EXCLUDED_PATHS=/wp-admin,/wp-login.php

# Only cache paths matching this regex
# .* = cache everything (default)
# /blog/.* = only cache /blog/ pages
# /(products|catalog)/.* = only cache products and catalog
INCLUDED_PATHS=.*

# ============================================
# ⚡ PERFORMANCE TUNING
# ============================================

# Backend request timeout in seconds
# Increase for slow backends or large file downloads
# 30 = default (good for most sites)
# 60 = slow CMS or large media files
# 10 = fast static site generators
PROXY_TIMEOUT=30

# Enable gzip compression for responses
# true = Compress HTML/CSS/JS (recommended, saves bandwidth)
# false = No compression (use if backend already compresses)
ENABLE_GZIP=true

# ============================================
# 🔒 SECURITY SETTINGS
# ============================================

# Verify SSL certificates on backend connections
# true = Verify certificates (recommended for production)
# false = Skip verification (only for dev/self-signed certs)
ENABLE_SSL_VERIFY=true

# HTTP methods allowed through the proxy
# GET,HEAD = Read-only (safest, recommended)
# GET,HEAD,POST = Allow form submissions
# GET,HEAD,POST,PUT,DELETE = Full API proxy (not recommended)
ALLOWED_METHODS=GET,HEAD

# ============================================
# 🐛 DEBUGGING
# ============================================

# Enable detailed logging to /var/log/apache2/proxy-debug.log
# true = Verbose logging (for development/troubleshooting)
# false = Minimal logging (for production)
DEBUG_MODE=false

# ============================================
# 🐳 DOCKER COMPOSE SETTINGS
# ============================================

# Host port to expose proxy on
# 80 = HTTP (default)
# 8080 = Alternative HTTP port
# 443 = HTTPS (requires SSL termination in front)
PROXY_PORT=80

# ============================================
# 📝 EXAMPLE CONFIGURATIONS
# ============================================

# 🎪 Event Website (updated 3x/year)
# TARGET_HOST=cms.conference2026.internal
# PUBLIC_HOST=conference2026.com
# CACHE_MAX_AGE=604800
# EXCLUDED_PATHS=/admin,/register/payment

# 💼 Personal Portfolio (updated monthly)
# TARGET_HOST=portfolio-cms.local
# PUBLIC_HOST=johndoe.dev
# CACHE_MAX_AGE=2592000
# EXCLUDED_PATHS=/contact-submit

# 🍕 Restaurant Site (menu updated weekly)
# TARGET_HOST=restaurant-wp.internal
# PUBLIC_HOST=pizzamario.com
# CACHE_MAX_AGE=86400
# EXCLUDED_PATHS=/order,/booking

# 🛒 E-Commerce (product catalog)
# TARGET_HOST=shop.backend.com
# PUBLIC_HOST=shop.com
# CACHE_MAX_AGE=3600
# EXCLUDED_PATHS=/cart,/checkout,/my-account,/admin

# 🧪 Development (no caching, debug on)
# TARGET_HOST=localhost:8080
# PROXY_SCHEME=http
# CACHE_MAX_AGE=0
# DEBUG_MODE=true
# ENABLE_SSL_VERIFY=false
