# 🎯 Core Settings
TARGET_HOST=ptr.example.com
PUBLIC_HOST=example.com
PROXY_SCHEME=https

# ⏱️ Caching Headers
CACHE_MAX_AGE=3600
CACHE_STALE_REVALIDATE=86400
CACHE_STALE_ERROR=86400
ENABLE_ETAG=true

# 🚫 Path Control (comma-separated, regex supported)
EXCLUDED_PATHS=/wp-admin,/wp-login.php,/wp-json,/xmlrpc.php
INCLUDED_PATHS=.*

# ⚙️ Performance
PROXY_TIMEOUT=30
ENABLE_GZIP=true

# 🔒 Security
ENABLE_SSL_VERIFY=true
ALLOWED_METHODS=GET,HEAD

# 🪵 Debugging
DEBUG_MODE=false
